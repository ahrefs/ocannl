#include <cuda_fp16.h>
#include <cuda_bf16.h>

/* Define math constants that would normally come from <math.h> */
#ifndef INFINITY
#define INFINITY __int_as_float(0x7f800000)
#endif
#ifndef NAN
#define NAN __int_as_float(0x7fffffff)
#endif
extern "C" __global__ void out_fwd(
    float *out) {
  /* FIXME: single-threaded for now. */if (threadIdx.x != 0 || blockIdx.x != 0) { return; };

  /* Local declarations and initialization. */
  float sparse[12] = {0};

  /* Main logic. */
  /* out fwd */
  for (unsigned int i7 = 0; i7 <= 3; ++i7) {
    sparse[(i7) * 3 + 0] = (float)(i7);
  }
  for (unsigned int i10 = 0; i10 <= 3; ++i10) {
    out[i10] = (sparse[(i10) * 3 + 2] * sparse[(i10) * 3 + 2]);
  }
  /* end */
}
