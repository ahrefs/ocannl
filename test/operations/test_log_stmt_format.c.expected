
#include <stdio.h>
#include <math.h>
#include <stdint.h>
#include <string.h>
#include <stdlib.h>

/* No longer need export macros since we're using textual prepending */

 void c_fwd(
    const char* log_file_name,
    float *a,
    float *b,
    float *c) {
  FILE* log_file = NULL;
  if (log_file_name) {
    log_file = fopen(log_file_name, "w");
  }
  /* Debug initial parameter state. */

  if (log_file_name && log_file) fprintf(log_file, "float *a &[1] = %p\n", (void*)a);
  if (log_file_name && log_file) fprintf(log_file, "float *b &[1] = %p\n", (void*)b);
  if (log_file_name && log_file) fprintf(log_file, "float *c &[1] = %p\n", (void*)c);
  /* Local declarations and initialization. */

  /* Main logic. */
  if (log_file_name && log_file) fprintf(log_file, "COMMENT: c fwd\n");
  {
    float new_set_v = (a[0] + b[0]);
    if (log_file_name && log_file) fprintf(log_file, "# c[0] := (a[0] + b[0]);\n");
    if (log_file_name && log_file) fprintf(log_file, "c[%u]{=%de-3} = %de-3 = (a[%u]{=%de-3} + b[%u]{=%de-3})\n",
        0,
        (int)(c[0] * 1000.0),
        (int)(new_set_v * 1000.0),
        0,
        (int)(a[0] * 1000.0),
        0,
        (int)(b[0] * 1000.0));
    fflush(log_file);
    c[0] = new_set_v;
  }
  if (log_file_name && log_file) fprintf(log_file, "COMMENT: end\n");
  if (log_file) { fclose(log_file); log_file = NULL; }

}