; cifar_conv is a slow training run: gated behind the `slow` alias instead of
; `runtest` so `dune runtest` stays fast. Still compiled by `dune build @check`.
; Run with: dune build @slow (or `dune build @runtest @slow` for everything).

(executable
 (name cifar_conv)
 (modules cifar_conv)
 (libraries ocannl dataprep conv_data unix)
 (preprocess
  (pps ppx_here ppx_ocannl)))

(rule
 (alias slow)
 (package neural_nets_lib)
 (deps
  ocannl_config
  (env_var OCANNL_BACKEND))
 ; no-infer keeps cifar_conv.actual from becoming a build target (see mlp_names).
 (action
  (no-infer
   (progn
    (with-stdout-to
     cifar_conv.actual
     (run %{dep:cifar_conv.exe}))
    (diff cifar_conv.expected cifar_conv.actual)))))

; fsm_transformer is a larger transformer training integration test. Keep it compiled during
; normal builds, but run it only through @slow so Metal runtest does not depend on a long pipeline
; compilation that can fail with Metal's XPC compiler service under load.

(executable
 (name fsm_transformer)
 (modules fsm_transformer)
 (libraries ocannl)
 (preprocess
  (pps ppx_here ppx_ocannl)))

(rule
 (alias slow)
 (package neural_nets_lib)
 (deps
  ocannl_config
  (env_var OCANNL_BACKEND))
 (action
  (no-infer
   (progn
    (with-stdout-to
     fsm_transformer.actual
     (run %{dep:fsm_transformer.exe}))
    (diff fsm_transformer.expected fsm_transformer.actual)))))

