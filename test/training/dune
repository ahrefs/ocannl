; bigram is a training integration run: gated behind the `slow` alias so default runtest stays
; bounded on the Metal backend.

(executable
 (name bigram)
 (modules bigram)
 (libraries ocannl dataprep)
 (preprocess
  (pps ppx_here ppx_ocannl)))

(rule
 (alias slow)
 (package neural_nets_lib)
 (deps
  ocannl_config
  (env_var OCANNL_BACKEND))
 (action
  (no-infer
   (progn
    (with-stdout-to
     bigram.actual
     (run %{dep:bigram.exe}))
    (diff bigram.expected bigram.actual)))))

