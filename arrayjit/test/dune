; Built and run only on macOS, where the Metal backend (the `metal` package)
; is available; skipped on other systems via `enabled_if`.
(test
 (name test_metal_storage_mode)
 (package arrayjit)
 (enabled_if
  (= %{system} macosx))
 (modules test_metal_storage_mode)
 (deps ocannl_config)
 (libraries base stdio metal arrayjit.ir arrayjit.metal_backend))
